[Unit]
Description=Network Pulse Dashboard - Live Device Monitor
After=network.target

[Service]
Type=simple
User=yb
Group=yb
WorkingDirectory=/usr/local/yb/.Network/dashboard
ExecStart=/usr/bin/python3 /usr/local/yb/.Network/dashboard/app.py
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

# Security
# NoNewPrivileges=yes blocks sudo/setuid; the Audit tab runs read_cmd_exec_audit.sh via sudo -n.
# Omit NoNewPrivileges or run the dashboard interactively if you need Audit.
NoNewPrivileges=yes
PrivateTmp=yes

[Install]
WantedBy=default.target
